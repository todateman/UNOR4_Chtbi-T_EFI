@startuml Arduino_ECU_Workflow
skinparam backgroundColor #FFFFFF
skinparam activity {
  BackgroundColor<<ISR>> #FFF2CC
  BackgroundColor<<RTOS>> #E1F5FE
  BackgroundColor<<Routine>> #E8F5E9
  BackgroundColor<<Setup>> #F3E5F5
}

title UNOR4_Chtbi-T_EFI ワークフロー(詳細版)

partition "setup()" <<Setup>> {
  start
  :シリアル初期化(USB/Serial1);
  :ピンモード設定(入力/出力\nLOWアクティブ出力初期HIGH);
  if (SD分岐 rmc_ra4m1_20) then (yes)
    :SD.begin / parseCSV();
  else (no)
    :SD未使用メッセージ;
  endif
  if (MA735 SPI 有効?) then (yes)
    :SPI.begin, CS設定;
    :readMA735SPI() 初期角度取得;
  endif
  if (AFR 有効?) then (yes)
    :AFR 初期化(未実装枠);
  endif
  :attachInterrupt\nNE_A->ReadNe_ISR(RISING)\nWH->WH_PULSE_ISR(FALLING)\nG->G_PULSE_ISR(CHANGE);
  :AGTimer.init(24us, Routine);\nAGTimer.start();
  :xTaskCreate(statusTask,500ms);\nvTaskStartScheduler();
  stop
}

partition "割込み" <<ISR>> {
  :WH_PULSE_ISR;
  :micros();
  :speedBefore→now差分でspeedWidth更新;
  :速度再計算\nspeed = (36000 * PERIMETER_MM) / dt;\n上限 99.9km/h(内部999);
  :距離(mm)加算→km更新;

  :ReadNe_ISR;
  :NE_B位相でNe_deg±1 (A立上がり);
  if (NE_Z立上がり) then (yes)
    :tachoWidth更新;\nRPM = 60,000,000 / tachoWidth;\n異常値(>10000RPM)は無視;
    if (Ne_deg>360 and G_Flag) then (sync)
      :Ne_deg=0; G_Flag=false;\nCycleReset=true;
    endif
  endif

  :G_PULSE_ISR;
  :G_Pulse=true;\nG_Flag=true (立上);\n(リリースはRoutineで処理)
}

partition "Routine(24µs)" <<Routine>> {
  start
  :STR_IN読取り(LOW=ON);
  if (AFR有効?) then (yes)
    :updateAFR();
  endif
  if (MA735有効?) then (yes)
    :Ne_deg = readMA735SPI();
  else (no)
    if (Encoder無効?) then (yes)
      :Ne_deg += ROUTINE_CYCLE_US / usecperdig;
    endif
  endif
  :MAP選択ロジック更新;
  if (スタータON) then (start)
    :INJ= start_INJ_time;\nIGN= start_IGN_CA;
  else (run)
    if (SDMapEnabled) then (SD)
      :parseCSVで読み込んだMAP使用(未実装枠);
    else (default)
      :defaultMapからRPMで選択\n見つからなければ INJ/IGN=0;
    endif
  endif
  :G_IN入力に応じて\nG_Pulse/G_Flag更新;
  :カム同期タイムアウト監視\n(>50msでcycleReset);
  if (CycleReset) then (yes)
    :updateEngineMap();
    :inj_end_ca選択\n(始動時:start_INJ_END_CA / 通常:INJ_END_CA);
    :INJ_STR_CA逆算\n(0CA跨ぎ時は+720で正規化);
    :噴射中(INJ_Status==2)はINJ状態維持\nそれ以外はINJ_Status=1/INJ_His=false;\nIGN初期化; Gフラグクリア;\ninj360Reset=false;
    :CycleReset=false;
  endif
  if (スタートOFFからON) then (edge)
    :cycleReset();
  endif

  :360CA安全リセット;
  if (Ne_deg >= 360 and !inj360Reset) then (yes)
    if (INJ_Status==2) then (噴射継続中)
      :INJ HIGH(強制OFF)\n燃料量積算; INJ_Status=1;
    endif
    :inj360Reset=true;
  endif

  if (ENG_ON and INJ_Status==1 and !INJ_His) then (ready)
    if (Ne_deg >= INJ_STR_CA) then (fire)
      :timeNow_INJ_ON=micros();\nINJ LOW; INJ_Status=2;\nINJ_His=true;
    endif
  endif
  if (INJ_Status==2) then (hold)
    :injDuration = calculatedINJ_time * 100 (µs);\nIncrease_Fuelによる補正位置(未実装);
    if (micros()-timeNow_INJ_ON >= injDuration) then (elapsed)
      :timeNow_INJ_OFF=micros();\nINJ HIGH; INJ_Status=1;
      :燃料量積算\n gasml += (((Δt)*0.0000007)+0.0015)/1.5073;
    endif
  endif

  if (ENG_ON and IGN_Status==1 and !IGN_His) then (ready)
    if (Ne_deg >= 360 - calculatedIGN_CA - Dwell_Time_CA) then (fire)
      :timeNow_IGN_ON=micros();\nIGN LOW; IGN_Status=2;\nIGN_His=true;
    endif
  endif
  if (IGN_Status==2) then (hold)
    if (Ne_deg >= 360 - calculatedIGN_CA || micros()-timeNow_IGN_ON >= 5000) then (>=5ms)
      :timeNow_IGN_OFF=micros();\nIGN HIGH; IGN_Status=1;
    endif
  endif

  :キル/スタート状態評価;
  if (ENGOFF_IN == LOW?) then (運転許可)
    if (startState == LOW?) then (自動モード有効)
      if (!ENG_ON and !cranking and !crankResting\nand !crankFailed and speed < 20km/h?) then (始動条件成立)
        :ENG_ON=true; cranking=true; Launch=true;\nSTR_OUT LOW; crankCycles++;\ncrankOnTime=millis();
      endif
      if (cranking?) then (yes)
        if (millis()-crankOnTime >= 2000ms?) then (タイムアウト)
          :cranking=false; ENG_ON=false;\nSTR_OUT HIGH;\ncrankResting=true; crankRestTime=millis();
        elseif (tachoRpm >= 1500rpm x 0.1s?) then (始動完了)
          :cranking=false;\nSTR_OUT HIGH;\ncrankCycles=0;
        endif
      endif
      if (crankResting?) then (yes)
        if (millis()-crankRestTime >= 1000ms?) then (休止完了)
          if (crankCycles >= 3?) then (3サイクル到達)
            :crankFailed=true;\n(キルスイッチ操作でリセット);
          else (再始動)
            :ENG_ON=true; cranking=true;\nSTR_OUT LOW; crankCycles++;\ncrankOnTime=millis();
          endif
        endif
      endif
      if (ENG_ON and speed >= 30km/h?) then (停止条件)
        :ENG_ON=false; cranking=false;\ncrankResting=false; crankCycles=0;\ncrankFailed=false; STR_OUT HIGH;
      endif
    else (自動モード無効)
      :ENG_ON=false; cranking=false;\ncrankResting=false; crankCycles=0;\ncrankFailed=false; STR_OUT HIGH;
    endif
  else (キルスイッチON)
    :ENG_ON=false; cranking=false;\ncrankResting=false; crankCycles=0;\ncrankFailed=false; STR_OUT HIGH;
  endif
  stop
}

partition "statusTask(500ms)" <<RTOS>> {
  start
  if (Launch) then (yes)
    :DISRESET LOW;\nworktime更新;
  else (no)
    :DISRESET HIGH;\n統計(距離/燃料)リセット;
  endif
  :INJ_timems, dispergas計算;
  :停止減衰(速度):\n最後WHからの経過(age)で速度再計算・低下;\n約8s(>8,000,000µs)で強制0;
  :無信号でRPMゼロ化(>1.2s = 1,200,000µs);
  :シリアル出力フィールド:\nRPM\tINJ(ms)\tIGN_CA\tspeed(km/h,0.1)\tdistance(km)\tfuel(ml)\tkm/L\tworktime(s)\tNe_deg;\nSerial1はCSV同順;
  stop
}

legend left
usecperdigモデル:
- NE_Aパルス間隔(µs/deg)を基に推定補間 (Encoder無効かつMA735無効時)
- 簡易平滑例: (prev*3 + dt)/4
- 異常(0や過大)は無視
endlegend

legend right
数値注記:
- ROUTINE_CYCLE_US=24µs, PERIMETER_MM=1548mm, 速度上限=99.9km/h(内部999)
- カム同期タイムアウト≈50ms, RPMゼロ化≈1.2s, 速度強制ゼロ≈8s, 点火保持5ms
- 0CA跨ぎ噴射: INJ_STR_CA<0の場合+720で正規化(0〜720CA範囲)
- 360CA安全リセット: 1サイクル1回限り、噴射継続中を強制OFF
- 自動始動: speed<20km/h→スタータON(最大2s)→1s休止→最大3サイクル
- 自動停止: speed>=30km/h→ENG_OFF
endlegend

 

@enduml